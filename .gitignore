# LaTeX build artifacts
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg

# Claude Code local settings
.claude/settings.local.json

# macOS
.DS_Store

# interview-prep generated dashboard
interview-prep/index.html

# master resume build artifacts (regenerated by update-master on promote)
master/resume.pdf
master/resume.txt

# pre-promote backups (git history is the real version control; these are belt-and-suspenders)
master/resume.backup-*.tex

# raw source-of-record binaries (large/personal HR docs); markdown in this dir is tracked
master/additional-context/*.pdf

# Python
__pycache__/

# ---- Your private workspace data (never published) -------------------------
# The skills read/write these relative to where you launch Claude Code. They are
# yours alone — recreate the skeleton from examples/ with `bash scaffold.sh`.
# Anchored to repo root with a leading slash so examples/ stays tracked.
/.jobforge.yml
/master/
/applications/
/interview-prep/topics/
/interview-prep/notes/
/interview-prep/suggested.md
/interview-prep/index.html
/job_description/
