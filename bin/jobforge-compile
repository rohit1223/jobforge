#!/usr/bin/env bash
# jobforge-compile — compile a resume .tex -> ATS-optimized PDF (page guard,
# pdftotext ATS extraction, contact-block extraction check). Wrapper around the
# bundled compile-resume.sh.
#
# Usage: jobforge-compile <path/to/resume.tex>
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec bash "$here/../skills/tailor-application/scripts/compile-resume.sh" "$@"
